# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# LLM - use one of the ones provided below
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# LLM provider: "anthropic", "openai", "openrouter", or "gemini"
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5

# Browser automation
HEADLESS_BROWSER=false
IMAGE_GEN_TOOL=leonardo       # Options: leonardo, ideogram, manual
VIDEO_GEN_TOOL=grok           # Options: grok, manual

IMAGE_GEN_URL=https://app.leonardo.ai/ai-generations
VIDEO_GEN_URL=https://x.ai/grok

# Playwright auth state files (saved after first login)
LEONARDO_AUTH_STATE=auth/leonardo_state.json
GROK_AUTH_STATE=auth/grok_state.json

# Output paths
OUTPUT_IMAGES_DIR=output/images
OUTPUT_VIDEOS_DIR=output/videos

# LangGraph state persistence
SQLITE_DB_PATH=pipeline_state.db

# Generation timeouts (seconds)
IMAGE_GEN_TIMEOUT=120
VIDEO_GEN_TIMEOUT=300
